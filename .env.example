# ============================================
# SPMB-WA Environment Configuration
# Copy this file to .env and fill in the values
# ============================================

# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=8h

# MongoDB
MONGODB_URI=mongodb://devspmbwa:devspmbwa@localhost:27017/devspmbwa

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=your-bucket-name
R2_REGION=auto
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_PUBLIC_URL=https://static.domain.com
R2_PREFIX=upload-example

# ScholarGate SSO
SSO_BASE_URL=https://scholargate.example.com
SSO_API_KEY=your-scholargate-api-key

# Google OAuth (for admin/operator login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
