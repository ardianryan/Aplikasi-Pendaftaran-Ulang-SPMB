# ============================================
# SPMB-WA Environment Configuration
# Copy this file to .env and fill in the values
# ============================================

# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=8h

# MongoDB
MONGODB_URI=mongodb://devspmbwa:devspmbwa@localhost:27017/devspmbwa

# Cloudflare R2, ScholarGate SSO, and Google OAuth are now configured dynamically
# directly from the Admin settings dashboard and stored in the database.
# Do NOT configure them in this .env file.

